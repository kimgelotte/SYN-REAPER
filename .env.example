# SYN-REAPER Settings
# Copy to .env and fill in values. Never commit .env.
# Values: true/false, 1/0, yes/no for booleans.

# --- Scan Settings (main.py) ---
# These become defaults; CLI flags override.

# Profile: quick | standard | deep | pentest (deep + web-advanced)
# SCAN_PROFILE=standard

# Individual checks (true/false)
# SCAN_EXPLOIT=false
# SCAN_BRUTEFORCE=false
# SCAN_AI_BRUTEFORCE=false   # Use AI to suggest bruteforce credentials per service
# SCAN_SSL_CHECK=false
# SCAN_SSH_AUDIT=false
# SCAN_WEB_DEEP=false
# SCAN_INJECTION=false
# SCAN_WEB_ADVANCED=false   # XSS / path traversal probes (pentest-level)
# SCAN_WIFI=false           # Scan nearby WiFi networks (system wireless adapter)
# SCAN_INCLUDE_ROUTER=false  # Include router (gateway) in pen test
# SCAN_OBFUSCATE=false       # Obfuscate: browser-like UA, random port order, pacing (less likely to be blocked)
# SCAN_POST_EXPLOIT=false    # Post-exploitation recon after brute force (SMB/FTP/SSH/DB enum); auto with pentest profile

# SCAN_UDP=false
# SCAN_FINGERPRINT=false
# SCAN_TYPE=connect
# SCAN_TIMEOUT=1.0
# SCAN_COMPLIANCE=

# --- AI Report Analysis (analyze.py) ---

# OpenAI (cloud) - reports anonymized by default
# OPENAI_API_KEY=your-openai-api-key-here

# Self-hosted (Ollama) - no key needed
# OPENAI_API_BASE=http://localhost:11434/v1

# Force anonymization: true = always anonymize, false = never, unset = auto (external=yes, local=no)
# AI_ANONYMIZE=true

# Model for AI analysis and AI agent (red team, pen-test decisions).
# Ollama (local): xploiter/the-xploiter = pen-test specialist (~9GB); or qwen2.5:7b / llama3.1 for general.
# OpenAI: gpt-4o-mini or gpt-4o. Unset = auto (Ollama -> llama3.1, OpenAI -> gpt-4o-mini).
# AI_MODEL=xploiter/the-xploiter
